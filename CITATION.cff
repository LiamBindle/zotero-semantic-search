    given-names: "Liam"
license: AGPL-3.0
repository-code: "https://github.com/LiamBindle/zotero-private-search"
url: "https://github.com/LiamBindle/zotero-private-search"
keywords:
  - zotero
  - semantic-search
  - privacy
  - airgap
  - local-ai
  - indigenous-research
  - irb
